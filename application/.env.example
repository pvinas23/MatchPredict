# MatchPredict environment variables.
# Copy this file to .env and replace the placeholder values before running the app.

# MySQL connection settings for local development.
# These values are read by config.py and used by the database connection helper.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=matchpredict_user
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=matchpredict
MYSQL_CHARSET=utf8mb4

# Flask runtime settings.
# SECRET_KEY should be a random string in local development and a stronger
# secret in any deployed environment.
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change_me
